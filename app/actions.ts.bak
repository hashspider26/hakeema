// Profile Management Actions
export async function updateUserProfile(
    userId: string,
    data: {
        name?: string;
        bio?: string;
        avatarUrl?: string;
        coverImage?: string;
        instagram?: string;
        tiktok?: string;
        website?: string;
    }
) {
    await prisma.user.update({
        where: { id: userId },
        data,
    });

    revalidatePath("/dashboard/profile");
    revalidatePath("/onboarding");
}

export async function completeOnboarding(userId: string) {
    await prisma.user.update({
        where: { id: userId },
        data: {
            onboardingCompleted: true,
            profileCompleted: true,
        },
    });

    revalidatePath("/onboarding");
    revalidatePath("/dashboard");
}

export async function checkProfileCompletion(userId: string) {
    const user = await prisma.user.findUnique({
        where: { id: userId },
        select: {
            profileCompleted: true,
            onboardingCompleted: true,
        },
    });

    return user;
}

// Page Creation Actions
export async function createPage(
    userId: string,
    data: {
        name: string;
        slug: string;
        pageType: 'STORE' | 'SUPPLIER';
        bannerUrl?: string;
        theme?: string;
        description?: string;
    }
) {
    // Check if user already has a page of this type
    const existingUserPages = await prisma.page.findMany({
        where: {
            userId,
            pageType: data.pageType,
        },
    });

    if (existingUserPages.length > 0) {
        throw new Error(`You already have a ${data.pageType.toLowerCase()} page`);
    }

    // Validate slug format (alphanumeric and hyphens only)
    const slugRegex = /^[a-z0-9-]+$/;
    if (!slugRegex.test(data.slug)) {
        throw new Error("URL slug can only contain lowercase letters, numbers, and hyphens");
    }

    // Check if slug matches any existing username (to avoid conflicts with profile routes)
    const existingUserWithSlug = await prisma.user.findUnique({
        where: { username: data.slug },
    });

    if (existingUserWithSlug) {
        throw new Error("This URL is reserved by a user profile");
    }

    // Check if slug is already taken by another page
    const existingPage = await prisma.page.findUnique({
        where: { slug: data.slug },
    });

    if (existingPage) {
        throw new Error("This page URL is already taken");
    }

    await prisma.page.create({
        data: {
            userId,
            name: data.name,
            slug: data.slug,
            pageType: data.pageType,
            bannerUrl: data.bannerUrl,
            theme: data.theme || "default",
            description: data.description,
        },
    });

    revalidatePath("/dashboard/pages");
    revalidatePath(`/page/${data.slug}`);
}

export async function getUserPages(userId: string) {
    return await prisma.page.findMany({
        where: { userId },
        include: {
            products: {
                include: {
                    product: true,
                },
            },
        },
        orderBy: {
            createdAt: 'desc',
        },
    });
}

export async function getPageBySlug(slug: string) {
    return await prisma.page.findUnique({
        where: { slug },
        include: {
            user: {
                select: {
                    id: true,
                    name: true,
                    username: true,
                    bio: true,
                    avatarUrl: true,
                },
            },
            products: {
                include: {
                    product: {
                        include: {
                            supplier: {
                                select: {
                                    id: true,
                                    name: true,
                                },
                            },
                            analytics: true,
                        },
                    },
                },
            },
        },
    });
}

export async function updatePage(
    pageId: string,
    data: {
        name?: string;
        bannerUrl?: string;
        theme?: string;
        description?: string;
    }
) {
    await prisma.page.update({
        where: { id: pageId },
        data,
    });

    const page = await prisma.page.findUnique({
        where: { id: pageId },
        select: { slug: true },
    });

    if (page) {
        revalidatePath(`/page/${page.slug}`);
    }
    revalidatePath("/dashboard/pages");
}

export async function deletePage(pageId: string) {
    const page = await prisma.page.findUnique({
        where: { id: pageId },
        select: { slug: true },
    });

    await prisma.page.delete({
        where: { id: pageId },
    });

    if (page) {
        revalidatePath(`/page/${page.slug}`);
    }
    revalidatePath("/dashboard/pages");
}
