"use server";

import { prisma } from "@/lib/prisma";
import { revalidatePath } from "next/cache";
import bcrypt from "bcryptjs";
import { Role } from "@prisma/client";

// Auth Actions
export async function registerUser(data: {
    email: string;
    password: string;
    name: string;
    username?: string;
}) {
    // Check if user already exists
    const existingUser = await prisma.user.findUnique({
        where: { email: data.email },
    });

    if (existingUser) {
        throw new Error("User with this email already exists");
    }

    // Check username uniqueness if provided
    if (data.username) {
        const existingUsername = await prisma.user.findUnique({
            where: { username: data.username },
        });

        if (existingUsername) {
            throw new Error("Username already taken");
        }
    }

    // Hash password
    const hashedPassword = await bcrypt.hash(data.password, 10);

    // Create user without role
    const user = await prisma.user.create({
        data: {
            email: data.email,
            password: hashedPassword,
            name: data.name,
            username: data.username,
            profileCompleted: false,
            onboardingCompleted: false,
        },
    });

    // Don't create page automatically - user will create pages from dashboard

    return { success: true, userId: user.id };
}

export async function getUserById(userId: string) {
    return await prisma.user.findUnique({
        where: { id: userId },
        select: {
            id: true,
            name: true,
            username: true,
            email: true,
            bio: true,
            avatarUrl: true,
            coverImage: true,
            instagram: true,
            tiktok: true,
            website: true,
            followers: true,
        },
    });
}

// Product Actions
export async function getProducts() {
    return await prisma.product.findMany({
        include: {
            supplier: {
                select: {
                    id: true,
                    name: true,
                },
            },
            analytics: true,
        },
        orderBy: {
            createdAt: "desc",
        },
    });
}

export async function getProductById(id: string) {
    return await prisma.product.findUnique({
        where: { id },
        include: {
            supplier: {
                select: {
                    id: true,
                    name: true,
                },
            },
            analytics: true,
        },
    });
}

// Page Actions (formerly Store Actions)
export async function getPageByUsername(username: string) {
    const user = await prisma.user.findUnique({
        where: { username },
        include: {
            pages: {
                include: {
                    products: {
                        include: {
                            product: {
                                include: {
                                    supplier: {
                                        select: {
                                            id: true,
                                            name: true,
                                        },
                                    },
                                    analytics: true,
                                },
                            },
                        },
                    },
                },
            },
        },
    });

    // Return the first STORE page (users can have max 1 store page)
    return (user as any)?.pages.find((p: any) => p.pageType === 'STORE');
}

export async function getInfluencerData(username: string) {
    return await prisma.user.findUnique({
        where: { username },
        include: {
            pages: {
                include: {
                    products: {
                        include: {
                            product: true,
                        },
                    },
                },
            },
        },
    });
}

export async function addProductToPage(username: string, productId: string) {
    const user = await prisma.user.findUnique({
        where: { username },
        include: { pages: true },
    });

    // Get the user's STORE page
    const storePage = (user as any)?.pages.find((p: any) => p.pageType === 'STORE');

    if (!user || !storePage) {
        throw new Error("User or store page not found");
    }

    // Check if product already exists in page
    const existingProduct = await prisma.pageProduct.findUnique({
        where: {
            pageId_productId: {
                pageId: storePage.id,
                productId,
            },
        },
    });

    if (existingProduct) {
        // Product already in page, just return without error
        return;
    }

    await prisma.pageProduct.create({
        data: {
            pageId: storePage.id,
            productId,
        },
    });

    revalidatePath("/store/dashboard/store");
    revalidatePath("/store/dashboard");
    revalidatePath("/products");
}

export async function removeProductFromPage(username: string, productId: string) {
    const user = await prisma.user.findUnique({
        where: { username },
        include: { pages: true },
    });

    // Get the user's STORE page
    const storePage = (user as any)?.pages.find((p: any) => p.pageType === 'STORE');

    if (!user || !storePage) {
        throw new Error("User or store page not found");
    }

    await prisma.pageProduct.deleteMany({
        where: {
            pageId: storePage.id,
            productId,
        },
    });

    revalidatePath("/store/dashboard/store");
    revalidatePath("/store/dashboard");
}

// Analytics Actions
export async function getAnalytics() {
    return await prisma.analytics.findMany({
        include: {
            product: true,
        },
    });
}

export async function getAnalyticsForProducts(productIds: string[]) {
    return await prisma.analytics.findMany({
        where: {
            productId: {
                in: productIds,
            },
        },
        include: {
            product: true,
        },
    });
}

// User/Page Actions
export async function updatePageDetails(
    username: string,
    data: { name: string; bio?: string; bannerUrl?: string; theme?: string }
) {
    const user = await prisma.user.findUnique({
        where: { username },
        include: { pages: true },
    });

    // Get the user's STORE page
    const storePage = (user as any)?.pages.find((p: any) => p.pageType === 'STORE');

    if (!user || !storePage) {
        throw new Error("User or store page not found");
    }

    await prisma.user.update({
        where: { username },
        data: {
            name: data.name,
            bio: data.bio,
        },
    });

    // Update page banner and theme
    await prisma.page.update({
        where: { id: storePage.id },
        data: {
            bannerUrl: data.bannerUrl,
            theme: data.theme,
        },
    });

    revalidatePath("/store/dashboard/store");
    revalidatePath(`/${username}`);
}

// User Actions
