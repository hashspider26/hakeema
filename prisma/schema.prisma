// This is your Prisma schema file

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?   // Add password back for NextAuth Credentials provider
  emailVerified DateTime?
  image         String?
  phone         String?
  address       String?
  city          String?
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  orders        Order[]
}

model Product {
  id                  String   @id @default(cuid())
  title               String
  slug                String   @unique
  description         String
  price               Int      // Price in PKR
  salePrice           Int?     // Optional sale price
  images              String   // JSON string of image URLs
  category            String
  stock               Int      @default(0)
  isFeatured          Boolean  @default(false)
  deliveryFee         Int      @default(0) // Delivery fee in PKR
  weight              Int      @default(0) // Weight in grams
  advanceDiscount     Int      @default(0) // Advance payment discount amount
  advanceDiscountType String   @default("PKR") // "PKR" or "PERCENT"
  
  position            Int      @default(0) // For custom sorting order
  
  orderItems  OrderItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id              String   @id @default(cuid())
  readableId      String?  @unique
  customerName    String
  phone           String
  address         String
  city            String
  totalAmount     Int
  discountAmount  Int      @default(0)
  paymentMethod   String   @default("COD") // COD, ADVANCE
  status          String   @default("PENDING") // PENDING, CONFIRMED, SHIPPED, DELIVERED, CANCELLED
  stockDeducted   Boolean  @default(false)
  userId          String?
  
  items           OrderItem[]
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Int     // Price at time of order

  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

// NextAuth Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    String   @default("UNREAD") // UNREAD, READ, REPLIED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  type        String   // PAGE_VIEW, ADD_TO_CART, INITIATE_CHECKOUT, PURCHASE
  path        String   // URL path
  pageTitle   String?
  referrer    String?  // Where they came from
  source      String?  // facebook, google, direct, etc.
  device      String?  // mobile, desktop, tablet
  browser     String?  // Chrome, Firefox, etc.
  os          String?  // Windows, iOS, Android
  ip          String?  // Hashed or masked for privacy
  sessionId   String?  // To group events
  productId   String?  // If it's a product-related event
  metadata    String?  // JSON string for additional info (params, conversion value, etc)
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([source])
}

